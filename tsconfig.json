{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@event": ["./events/index.ts"],
      "@event/schema": ["./events/schema.ts"],
      "@event/*": ["./events/pgc/*"]
    },
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "target": "ESNext"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "events/**/*.ts",
    "events/**/*.tsx",
    "tools/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
