{
  "name": "go-tournaments-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env EVENT=pgc next dev",
    "dev:pgc": "cross-env EVENT=pgc next dev",
    "dev:wagc": "cross-env EVENT=wagc next dev",
    "dev:pwgc": "cross-env EVENT=pwgc next dev",
    "dev:pagc": "cross-env EVENT=pagc next dev",
    "dev:pygc": "cross-env EVENT=pygc next dev",
    "dev:kpmc": "cross-env EVENT=kpmc next dev",
    "build": "next build",
    "build:pgc": "cross-env EVENT=pgc next build",
    "build:wagc": "cross-env EVENT=wagc next build",
    "build:pwgc": "cross-env EVENT=pwgc next build",
    "build:pagc": "cross-env EVENT=pagc next build",
    "build:pygc": "cross-env EVENT=pygc next build",
    "build:kpmc": "cross-env EVENT=kpmc next build",
    "start": "npx serve@latest out",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "extract:mp-db": "cross-env EVENT=pgc tsx tools/extract.ts",
    "build:templates": "cross-env EVENT=pgc tsx tools/templates.ts",
    "sgf:fix:pgc": "cross-env EVENT=pgc tsx tools/fix.ts",
    "sgf:match:pgc": "cross-env EVENT=pgc tsx tools/sgfMatcher/index.ts",
    "sgf:match:wagc": "cross-env EVENT=wagc tsx tools/sgfMatcher/index.ts",
    "sgf:match:kpmc": "cross-env EVENT=kpmc tsx tools/sgfMatcher/index.ts",
    "fmt": "prettier --check .",
    "fmt:write": "prettier --write ."
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "@resvg/resvg-js": "2.6.2",
    "@sabaki/go-board": "1.4.3",
    "@tailwindcss/postcss": "4.2.4",
    "@tanstack/react-query": "5.100.5",
    "@tanstack/react-table": "8.21.3",
    "@types/lodash-es": "4.17.12",
    "clsx": "2.1.1",
    "fast-glob": "3.3.3",
    "go-results-highlighter": "4.0.1",
    "lodash-es": "4.18.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "sharp": "0.34.5",
    "slugify": "1.6.9",
    "svgo": "4.0.1",
    "tailwind-merge": "3.5.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@sabaki/sgf": "3.4.7",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "cross-env": "10.1.0",
    "diff": "8.0.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "mysql2": "3.22.2",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0"
  },
  "overrides": {
    "@types/react": "19.2.14"
  }
}
