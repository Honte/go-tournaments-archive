{
  "name": "go-tournaments-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env EVENT=pgc next dev",
    "dev:pgc": "cross-env EVENT=pgc next dev",
    "dev:wagc": "cross-env EVENT=wagc next dev",
    "dev:pwgc": "cross-env EVENT=pwgc next dev",
    "build": "next build",
    "build:pgc": "cross-env EVENT=pgc next build",
    "build:wagc": "cross-env EVENT=wagc next build",
    "build:pwgc": "cross-env EVENT=pwgc next build",
    "start": "npx serve@latest out",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "extract:mp-db": "cross-env EVENT=pgc tsx tools/extract.ts",
    "build:templates": "cross-env EVENT=pgc tsx tools/templates.ts",
    "sgf:fix:pgc": "cross-env EVENT=pgc tsx tools/fix.ts",
    "sgf:match:pgc": "cross-env EVENT=pgc tsx tools/sgfMatcher/index.ts",
    "sgf:match:wagc": "cross-env EVENT=wagc tsx tools/sgfMatcher/index.ts",
    "sgf:match:pwgc": "cross-env EVENT=pwgc tsx tools/sgfMatcher/index.ts",
    "fmt": "prettier --check .",
    "fmt:write": "prettier --write ."
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "@sabaki/go-board": "1.4.3",
    "@tailwindcss/postcss": "4.2.2",
    "@tanstack/react-table": "8.21.3",
    "@types/lodash-es": "4.17.12",
    "clsx": "2.1.1",
    "convert-svg-to-png": "0.7.1",
    "fast-glob": "3.3.3",
    "go-results-highlighter": "4.0.1",
    "lodash-es": "4.18.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "slugify": "1.6.9",
    "svgo": "4.0.1",
    "tailwind-merge": "3.5.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@sabaki/sgf": "3.4.7",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "autoprefixer": "10.4.27",
    "cross-env": "10.1.0",
    "diff": "8.0.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "mysql2": "3.20.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "puppeteer": "24.40.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0"
  },
  "overrides": {
    "@types/react": "19.2.14"
  }
}
